{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": ["angular-eslint"],
  },
  "newProjectRoot": "projects",
  "projects": {
    "opencode-angular": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
        },
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
              },
            ],
            "styles": ["src/styles.css"],
            "allowedCommonJsDependencies": ["mermaid", "@ng-icons/octicons"],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "src/server.ts",
            },
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB",
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB",
                },
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": true,
                },
                "fonts": true,
              },
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts",
                },
              ],
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
            },
          },
          "defaultConfiguration": "production",
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "allowedHosts": ["localhost", "127.0.0.1"],
          },
          "configurations": {
            "production": {
              "buildTarget": "opencode-angular:build:production",
            },
            "development": {
              "buildTarget": "opencode-angular:build:development",
            },
          },
          "defaultConfiguration": "development",
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "coverage": true,
            "coverageExclude": ["src/main*.ts", "src/server.ts", "src/app/ui/**"],
            "coverageThresholds": {
              "statements": 97,
              "branches": 85,
              "functions": 68,
              "lines": 99,
            },
          },
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"],
          },
        },
      },
    },
  },
}
