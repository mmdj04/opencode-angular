# ===========================================
# opencode-angular - Environment Configuration
# ===========================================

# -------------------------------------------
# API Configuration
# -------------------------------------------
API_URL=http://localhost:3000
API_TIMEOUT=30000
API_KEY=

# -------------------------------------------
# Application
# -------------------------------------------
APP_ENV=development
APP_PORT=4200
APP_NAME=opencode-angular
APP_VERSION=0.0.0

# -------------------------------------------
# SSR Configuration
# -------------------------------------------
SSR_PORT=4000
SSR_ENABLED=true

# -------------------------------------------
# Authentication (se aplicável)
# -------------------------------------------
AUTH_SECRET=
AUTH_EXPIRATION=3600

# -------------------------------------------
# Analytics (opcional)
# -------------------------------------------
GA_TRACKING_ID=
SENTRY_DSN=

# -------------------------------------------
# Feature Flags
# -------------------------------------------
ENABLE_DARK_MODE=true
ENABLE_I18N=true
ENABLE_SSR=true
