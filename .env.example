# ===========================================
# Agentwork - Environment Configuration
# ===========================================

# -------------------------------------------
# Supabase
# -------------------------------------------
SUPABASE_URL=https://vmqiwwgtlkxmajorteor.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------
# Gemini API (chave padrão para agentes sem chave própria)
# -------------------------------------------
GEMINI_DEFAULT_KEY=

# -------------------------------------------
# Agent Configuration
# -------------------------------------------
AGENT_MAX_PROJECTS_PER_MONTH=3
AGENT_EXECUTION_INTERVAL_MINUTES=30
AGENT_QUIET_HOURS_START=22:00
AGENT_QUIET_HOURS_END=06:00

# -------------------------------------------
# Application
# -------------------------------------------
APP_ENV=development
APP_PORT=4200
APP_NAME=agentwork

# -------------------------------------------
# SSR Configuration
# -------------------------------------------
SSR_PORT=4000
SSR_ENABLED=true

# -------------------------------------------
# Feature Flags
# -------------------------------------------
ENABLE_DARK_MODE=true
ENABLE_SSR=true
