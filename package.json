{
  "name": "opencode-angular",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --code-coverage",
    "test:coverage:html": "ng test --code-coverage --browsers=ChromeHeadless",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json,md}\"",
    "typecheck": "tsc --noEmit",
    "security:check": "npm audit --audit-level=high",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:watch": "knip --watch",
    "knip:production": "knip --production --strict --cache",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:debug": "npx playwright test --debug",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report",
    "test:update": "ng test --watch=false --update-snapshots",
    "serve:ssr:opencode-angular": "node dist/opencode-angular/server/server.mjs",
    "prepare": "husky",
    "ui:add": "ng g @spartan-ng/cli:ui",
    "ui:theme": "ng g @spartan-ng/cli:ui-theme",
    "ui:healthcheck": "ng g @spartan-ng/cli:healthcheck",
    "ui:info": "ng g @spartan-ng/cli:info --json"
  },
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-server": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/ssr": "^22.0.2",
    "@ng-icons/core": "^33.2.4",
    "@ng-icons/lucide": "^33.2.4",
    "@spartan-ng/brain": "^0.0.1-alpha.718",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "embla-carousel": ">=8.0.0 <9.0.0",
    "embla-carousel-angular": ">=21.0.0 <23.0.0",
    "express": "^5.1.0",
    "mermaid": "^11.15.0",
    "ngx-scrollbar": "^19.1.5",
    "roughjs": "^4.6.6",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.2",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@playwright/test": "^1.61.0",
    "@spartan-ng/cli": "^0.0.1-alpha.718",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.9"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "overrides": {
    "vite": {
      "esbuild": "^0.28.0"
    }
  },
  "lint-staged": {
    "*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  }
}
