{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [],
  "project": ["src/**/*.ts", "e2e/**/*.ts"],
  "ignore": ["src/environments/environment.ts"],
  "ignoreDependencies": [
    "@angular-eslint/builder",
    "@commitlint/types",
    "@spartan-ng/cli",
    "embla-carousel",
    "embla-carousel-angular",
    "ngx-scrollbar"
  ],
  "ignoreExports": ["provideBrnButtonConfig", "buttonVariants", "provideHlmCardConfig"],
  "angular": true,
  "eslint": true,
  "prettier": true,
  "typescript": {
    "config": ["tsconfig*.json"]
  }
}
